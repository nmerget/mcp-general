{
  "name": "mcp-general",
  "version": "0.0.0",
  "description": "A generic MCP server that dynamically exposes tools, resources, and prompts based on a project-level config.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/nmerget/mcp-general.git",
    "directory": "packages/server"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "ai",
    "tools",
    "resources",
    "prompts",
    "cosmiconfig"
  ],
  "bin": {
    "mcp-general": "dist/index.js"
  },
  "types": "dist/types.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "cosmiconfig": "9.0.1",
    "cosmiconfig-typescript-loader": "6.3.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
